extends auth-layout

block content
  .register-box
    .register-logo
      a(href='/admin/login')
        b Admin
        |  Portal
    .card
      .card-body.register-card-body
        p.login-box-msg Register a new account

        form#signupForm
          .input-group.mb-3
            input#email.form-control(type='email', name='email', placeholder='Email', required=true, autocomplete='email')
            .input-group-append
              .input-group-text
                span.fas.fa-envelope
          .input-group.mb-3
            input#password.form-control(type='password', name='password', placeholder='Password', required=true, minlength='6', autocomplete='new-password')
            .input-group-append
              .input-group-text
                span.fas.fa-lock
          .input-group.mb-3
            input#confirmPassword.form-control(type='password', name='confirmPassword', placeholder='Confirm password', required=true, minlength='6', autocomplete='new-password')
            .input-group-append
              .input-group-text
                span.fas.fa-lock
          .row
            .col-12
              button.btn.btn-primary.btn-block(type='submit') Create Account

        p#signupError.auth-error.hidden.mt-2.mb-0
        p#signupSuccess.auth-success.hidden.mt-2.mb-0

        p.mb-0.mt-3
          a(href='/admin/login') I already have an account

        p.text-muted.mt-3.mb-0.small
          | Admin access is granted automatically for approved emails configured on the server.

block scripts
  script(src='https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2')
  script(src='/javascripts/admin-auth.js')
  script(src='/javascripts/admin-signup.js')
