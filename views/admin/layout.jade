doctype html
html
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    title= title
    link(rel='stylesheet', href='https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback')
    link(rel='stylesheet', href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css')
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css')
    link(rel='stylesheet', href='/stylesheets/admin.css')
  body.hold-transition.sidebar-mini.layout-fixed
    .wrapper
      nav.main-header.navbar.navbar-expand.navbar-white.navbar-light
        ul.navbar-nav
          li.nav-item
            a.nav-link(data-widget='pushmenu', href='#', role='button')
              i.fas.fa-bars
        ul.navbar-nav.ml-auto
          li.nav-item.d-none.d-sm-inline-block
            span.nav-link.text-muted#userEmail
          li.nav-item
            button#logoutBtn.nav-link.btn.btn-link Log out

      aside.main-sidebar.sidebar-dark-primary.elevation-4
        a.brand-link(href='/admin/products/page')
          span.brand-text.font-weight-light Admin Portal

        .sidebar
          nav.mt-2
            ul.nav.nav-pills.nav-sidebar.flex-column(data-widget='treeview', role='menu')
              li.nav-item
                a.nav-link(href='/admin/products/page', class=(activeNav === 'products' ? 'active' : ''))
                  i.nav-icon.fas.fa-box
                  p Products

      .content-wrapper
        .content-header
          .container-fluid
            .row.mb-2
              .col-sm-6
                h1.m-0= pageHeading || title
              .col-sm-6
                ol.breadcrumb.float-sm-right
                  block breadcrumb
                    li.breadcrumb-item
                      a(href='/admin/products/page') Home
                    li.breadcrumb-item.active= pageHeading || title

        section.content
          .container-fluid
            block content

      footer.main-footer
        strong Admin Portal
        |  &copy; 2026
        .float-right.d-none.d-sm-inline-block
          | v1.0

    script(src='https://cdn.jsdelivr.net/npm/jquery@3.6/dist/jquery.min.js')
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js')
    script(src='https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js')
    block scripts
